# Edwin backend — environment template.
#
# Copy to `.env` and fill in real values. Production deployments
# ignore .env entirely (see app/config.py::_resolve_env_file) — every
# key here must arrive as a real env var (Docker/K8s/App Service).
#
# IMPORTANT: every key below is REQUIRED. The backend has no defaults
# in `_EnvSettings` — a missing key crashes the process at boot with
# a clear "Field required" error. This is deliberate: it makes config
# drift and env-key typos visible immediately. To "leave a value blank"
# set the key with no value (e.g. `LANGFUSE_PROXY_TOKEN=`); that's
# different from omitting the line entirely.
#
# Typos in *unknown* keys are silently ignored (`extra="ignore"` on
# _EnvSettings) so the .env can also hold sibling-service config —
# but typos in keys we declare here will surface as missing-field
# errors because the matching field has no default to fall back to.

# ── App ─────────────────────────────────────────────────────────────────
APP_NAME=Edwin Slide Builder
# One of: development | staging | production
EDWIN_ENVIRONMENT=development
# URL of the separate db-service this backend proxies through to.
DB_SERVICE_URL=http://localhost:8001

# ── Azure AD (must match frontend VITE_AZURE_* values) ──────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Required in production. Locks the /api/admin/* routes to this app reg.
AZURE_ADMIN_CLIENT_ID=

# ── TLS / corporate CA (optional; never commit PEM bundles into git) ────
# JWKS fetching for Azure AD uses ssl.create_default_context, which reads
# os.environ — export ONE of these in your shell / IDE / container before
# starting uvicorn (a line in .env alone is not enough unless your runner
# injects it into the process environment):
#   SSL_CERT_FILE
#   REQUESTS_CA_BUNDLE
#   AZURE_CACERT_PATH
# See README "Repository hygiene" and server/backend/app/dependencies.py.

# ── AI / LLM provider ───────────────────────────────────────────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://your-proxy.example.com/v1
DEFAULT_LLM_MODEL=openai.gpt-5.5
# When blank, WebSearchTool falls back to the per-turn mainLoopModel.
SEARCH_LLM_MODEL=
STREAM_TIMEOUT_SECONDS=600
# One of: low | medium | high
REASONING_EFFORT=medium

# ── Observability (Langfuse) ────────────────────────────────────────────
# When LANGFUSE_ENABLED=true, both PUBLIC_KEY and SECRET_KEY are required
# (validated at boot). Disabled is the default for local dev.
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Bearer token for an upstream proxy in front of Langfuse (PwC-internal).
# Leave blank if calling Langfuse directly.
LANGFUSE_PROXY_TOKEN=
# Path to a custom CA bundle if the proxy uses a private CA.
LANGFUSE_CACERT_PATH=

# ── Logging ─────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_LOCAL_ENABLED=true
LOG_DIR=logs
# Azure Blob log sink. When LOG_AZURE_ENABLED=true,
# LOG_AZURE_CONNECTION_STRING is required (validated at boot).
LOG_AZURE_ENABLED=false
LOG_AZURE_CONNECTION_STRING=
LOG_AZURE_CONTAINER=logs
LOG_AZURE_BLOB_PREFIX=app
LOG_AZURE_BATCH_SIZE=100
LOG_AZURE_FLUSH_INTERVAL=30

# ── Compaction (agent-loop conversation compaction) ─────────────────────
COMPACTION_AUTO_TRIGGER_RATIO=0.70
COMPACTION_COLLAPSE_TRIGGER_LOW=0.60
COMPACTION_COLLAPSE_TRIGGER_HIGH=0.70
COMPACTION_PRESERVE_RECENT=6
COMPACTION_EMERGENCY_PRESERVE_RECENT=3
COMPACTION_MICRO_KEEP_LAST=4
# Phase-3 overrides. 0 = use the constant baked into
# services/compact/auto_compact.py and compact_warning_state.py
# (160K autocompact, 70% of that for the warning). Set > 0 to
# trigger compaction at smaller context sizes during testing.
EDWIN_AUTOCOMPACT_THRESHOLD_TOKENS=0
EDWIN_WARNING_THRESHOLD_TOKENS=0
